class {{ class }}Controller extends Controller
{
	/**
	 * Display a listing of the resource.
	 */
	public function index(): View
	{
		return view('{{ viewVariable }}.index');
		// return {{ class }}Resource::collection(
		// 	{{ class }}::paginate()
		// );
	}

	/**
	 * Show the form for creating a new resource.
	 */
	public function create(): View
	{
		return view('{{ viewVariable }}.create');
	}

	/**
	 * Store a newly created resource in storage.
	 */
	public function store(Store{{ class }}Request $request): RedirectResponse
	{
		// $item = {{ class }}::create(
		// 	$request->validated()
		// );

		$result = {{ class }}::create(
			$request->except('_token')
		);

		$result->hasManyRelationship()->createMany(
			$request->arrays
		);

		return redirect()->route('{{ modelVariable }}.index')->with('success', 'Data Added');
		// return new {{ class }}Resource($item);
	}

	/**
	 * Display the specified resource.
	 */
	public function show({{ class }} ${{ modelVariable }}): View
	{
		return view('{{ viewVariable }}.show', ['var' => ${{ modelVariable }}]);
		// return new {{ class }}Resource(${{ modelVariable }});
	}

	/**
	 * Show the form for editing the specified resource.
	 */
	public function edit({{ class }} ${{ modelVariable }}): View
	{
		return view('{{ viewVariable }}.edit', ['var' => ${{ modelVariable }}]);
	}

	/**
	 * Update the specified resource in storage.
	 */
	public function update(
		Update{{ class }}Request $request,
		{{ class }} ${{ modelVariable }}
	): RedirectResponse
	{
		// ${{ modelVariable }}->update(
		// 	$request->validated()
		// );


		${{ modelVariable }}->update(
			$request->except('_token', '_method')
		);

		foreach ($request->arrays as $array) {
			${{ modelVariable }}->hasManyRelationship()->updateOrCreate(
				['id' => $array['id'] ?? null],
				$array
			);
		}

		return redirect()->route('{{ modelVariable }}.index')->with('success', 'Data Updated');
		// return new {{ class }}Resource(${{ modelVariable }});
	}

	/**
	 * Remove the specified resource from storage.
	 */
	// public function destroy({{ class }} ${{ variable }}): JsonResponse
	public function destroy({{ class }} ${{ modelVariable }}): JsonResponse
	{
		${{ modelVariable }}->delete();
		return response()->json([
			'status' => 'success',
			'message' => 'Data Deleted',
		]);
	}
}
